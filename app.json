{
  "expo": {
    "name": "Hunky Dory",
    "slug": "hunky-dory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFF4F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hunkydory.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EFF4F2"
      },
      "package": "com.hunkydory.app"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hunky Dory to access your photos for meal check-ins.",
          "cameraPermission": "Allow Hunky Dory to use your camera for meal photos."
        }
      ]
    ]
  }
}
